        {
          "name": "Notification Service Info",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{notificationServiceUrl}}/actuator/info",
              "host": [
                "{{notificationServiceUrl}}"
              ],
              "path": [
                "actuator",
                "info"
              ]
            },
            "description": "Info endpoint for notification-service."
          },
          "response": []
        },
        {
          "name": "Notification Service Metrics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{notificationServiceUrl}}/actuator/metrics",
              "host": [
                "{{notificationServiceUrl}}"
              ],
              "path": [
                "actuator",
                "metrics"
              ]
            },
            "description": "Metrics index for notification-service."
          },
          "response": []
        }
      ]
    }
  ]
}
